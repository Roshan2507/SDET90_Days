package topInterviewQuestions;

public class LargestNumberInArray {

	public static void main(String[] args) {

			 int[] arr = {10, 45, 23, 78, 56};
			 int max =Integer.MIN_VALUE;
			 
			 for (int num : arr) {
			 if (num < max) 
				 max = num;
			 }
			 System.out.println("Largest: " + max);
	}

}

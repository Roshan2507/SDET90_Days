package TCSQuestions;

import java.time.Duration;
import java.util.List;

import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.chrome.ChromeDriver;import org.openqa.selenium.support.ui.ExpectedConditions;
import org.openqa.selenium.support.ui.WebDriverWait;

public class GrabThelistofSideBar {

	public static void main(String[] args) throws InterruptedException {

		
		WebDriver driver = new ChromeDriver();
		
		driver.get("https://www.amazon.in/");
		WebDriverWait wait = new WebDriverWait(driver,Duration.ofSeconds(10));
		
		
	WebElement icon =driver.findElement(By.xpath("//i[contains(@class,\"hm-icon nav-sprite\")]"));
	
	WebElement icons = wait.until(ExpectedConditions.elementToBeClickable(icon));
	icons.click();

		
		List<WebElement> listContent =driver.findElements(By.xpath
				("//div[text()=\"Digital Content and Devices\"]/following-sibling::ul//a"));
		
		List<WebElement> list =wait.until(ExpectedConditions.visibilityOfAllElements(listContent));
		
		System.out.println(list.size());
		
	   System.out.println(list);
		
	}

}

package topInterviewQuestions;

public class SwapWithout3rdV {

	public static void main(String[] args) {
		// TODO Auto-generated method stub

		int a =5;
		int b =10;
		System.out.println("Before Swap A: "+a+" B:"+b);
		a=a+b;//15
		b=a-b;//5
		a=a-b;
		System.out.println("After Swap A: "+a+" B:"+b);
	}

}

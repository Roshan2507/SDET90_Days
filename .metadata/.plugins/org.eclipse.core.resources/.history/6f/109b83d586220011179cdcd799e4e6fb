package com.yatra.automation;

import org.openqa.selenium.Alert;
import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.chrome.ChromeDriver;
import org.openqa.selenium.chrome.ChromeOptions;

public class YatraAutomationScript {

	public static void main(String[] args) {
		
		ChromeOptions cmoptions = new ChromeOptions();
		cmoptions.addArguments("--disable-notifications");
		
		WebDriver driver = new ChromeDriver(cmoptions);
		driver.manage().window().maximize();
		
		driver.get("https://www.yatra.com");
		
		By departureDate=By.xpath("//div[@aria-label=\"Departure Date inputbox\"]");
		WebElement depDate=driver.findElement(departureDate);
		depDate.click();
		
		
	}
}

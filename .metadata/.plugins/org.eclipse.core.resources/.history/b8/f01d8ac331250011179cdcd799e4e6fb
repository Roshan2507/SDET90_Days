package TCSQuestions;

public class RemoveDuplicateFromArray {

	public static void main(String[] args) {

		
		int [] arr = {1,2,3,4,4,5,6,1,2};
		
		for(int n:arr)
		{
			System.out.print(n);
		}
		
		for(int i=0;i<arr.length;i++)
		{
			for(int j=i+1;j<arr.length;j++)
			{
				if(arr[i]==arr[j])
				{
					System.out.print(arr[i]);
				}
			}
		}
	}

}
